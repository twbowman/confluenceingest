# Knowledge base Git repo (source of Markdown files)
KB_GIT_REPO_URL=git@gitlab.mycompany.com:your-org/knowledge-base.git
KB_GIT_BRANCH=master
KB_GIT_SSH_KEY=~/.ssh/id_rsa
KB_LOCAL_DIR=./knowledge-base

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB settings
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=knowledge_base
