# Confluence connection
CONFLUENCE_URL=https://wiki.mycompany.com
CONFLUENCE_PAT=your-personal-access-token-here
CONFLUENCE_SPACE_KEY=ENG,PRODUCT,OPS

# Optional: comma-separated page IDs to sync specific pages only
# CONFLUENCE_PAGE_IDS=12345,67890

# Output
OUTPUT_DIR=./knowledge-base

# Attachments — common directory for all page attachments (relative to OUTPUT_DIR)
# Centralized in anticipation of future blob storage migration
ATTACHMENTS_DIR=attachments
# Max file size in MB — attachments larger than this are skipped with a warning
ATTACHMENT_MAX_SIZE_MB=50

# Knowledge base Git repo (separate repo in GitLab for the exported Markdown)
KB_GIT_REPO_URL=git@gitlab.mycompany.com:your-org/knowledge-base.git
KB_GIT_BRANCH=master
KB_GIT_SSH_KEY=~/.ssh/id_rsa
KB_GIT_AUTHOR_NAME=confluence-sync
KB_GIT_AUTHOR_EMAIL=confluence-sync@mycompany.com
